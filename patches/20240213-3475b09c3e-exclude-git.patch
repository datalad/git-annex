Description: Exclude datalad/git-annex CI scaffolding from Debian source package
Origin: vendor, https://github.com/datalad/git-annex/commit/b4a7900e2b
Author: John T. Wodder II <git@varonathe.org>
Forwarded: not-needed
Last-Update: 2024-02-16
SPDX-FileCopyrightText: 2024 John T. Wodder II <git@varonathe.org>
SPDX-License-Identifier: AGPL-3.0-or-later
---
diff --git a/debian/source/options b/debian/source/options
new file mode 100644
index 0000000000..62612d7c71
--- /dev/null
+++ b/debian/source/options
@@ -0,0 +1,11 @@
+# Due to restrictions around allowed version strings, git-annex's Debian source
+# package has to use format 1.0, which doesn't ignore VCS files unless the
+# following explicit options are given:
+diff-ignore
+tar-ignore
+
+# Also ignore some trees specific to the datalad/git-annex build process:
+extend-diff-ignore = "(^|/)(\.github|clients|patches)($|/)"
+tar-ignore = .github
+tar-ignore = clients
+tar-ignore = patches
